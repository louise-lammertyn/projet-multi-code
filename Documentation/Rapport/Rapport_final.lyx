}
\end_layout

\end_inset

 
\begin_inset space \space{}

\end_inset


\begin_inset Newline newline
\end_inset

 On peut ainsi écrire 
\begin_inset Formula \[
A_\nu ({\color{red}r},{\color{green}z})=\sum\limits_{i=0}^{\infty} a_{i\nu} ({\color{green}z}) \times ({\color{red}r})^{\nu + i}
\]
\end_inset

et 
\begin_inset Formula \[
B_\nu ({\color{red}r},{\color{green}z})=\sum\limits_{i=0}^{\infty} b_{i\nu} ({\color{green}z}) \times ({\color{red}r})^{\nu + i}
\]
\end_inset


\begin_inset space \space{}

\end_inset


\begin_inset Newline newline
\end_inset

 On pose alors 
\begin_inset Formula $A_{\nu 0} ({\color{green}z})=\Phi_{\nu {\color{red}r}}$
\end_inset

 et 
\begin_inset Formula $B_{\nu 0} ({\color{green}z})=\Phi_{\nu i}$
\end_inset

, les composantes de Fourrier du potentiel sur l'axe. On peut alors insérer les coefficients de la série de Taylor dans les composantes de la série de Fourrier. On obtient alors 
\begin_inset Formula \[
A_\nu ({\color{red}r},{\color{green}z})=\sum\limits_{\lambda=0}^{\infty} \frac{(-1)^{\lambda}\times (\nu !)}{4^{\lambda}\times \lambda !\times (\lambda +\nu)!}
\times {\color{red}r}^{\nu +2\lambda} \times \Phi_{\nu {\color{red}r}}^{[2\lambda]}({\color{green}z}) 
\]
\end_inset

et 
\begin_inset Formula \[
B_\nu ({\color{red}r},{\color{green}z})=\sum\limits_{\lambda=0}^{\infty} \frac{(-1)^{\lambda}\times (\nu !)}{4^{\lambda}\times \lambda !\times (\lambda +\nu)!}
\times {\color{red}r}^{\nu +2\lambda} \times \Phi_{\nu i}^{[2\lambda]}({\color{green}z}) 
\]
\end_inset


\begin_inset ERT
status collapsed

\begin_layout Plain Layout
% dans les deux expression précédentes, quelles sont les bornes des sommes: i ou lambda? 
\end_layout

\begin_layout Plain Layout

\end_layout

\end_inset


\begin_inset space \space{}

\end_inset


\begin_inset Newline newline
\end_inset

 On peut alors écrire le potentiel 
\begin_inset Formula $\phi ({\color{red}r},{\color{blue}\theta},{\color{green}z})$
\end_inset

 comme une somme polynomiale avec les dérivées du potentiel pris sur l'axe optique comme coefficients des polynômes. On a alors
\end_layout

\begin_layout Standard

\lang french

\begin_inset Formula \[
\phi ({\color{red}r},{\color{blue}\theta},{\color{green}z})= \sum\limits_{\nu =0}^{\infty}
\sum\limits_{\lambda=0}^{\infty} \frac{(-1)^{\lambda}\times (\nu !)}{4^{\lambda}\times \lambda !\times (\lambda +\nu)!}
\times {\color{red}r}^{\nu +2\lambda} \times \left(\Phi_{\nu {\color{red}r}}^{[2\lambda]}({\color{green}z})\times cos(\nu{\color{blue}\theta}) + 
\Phi_{\nu i}^{[2\lambda]}({\color{green}z})\times sin(\nu{\color{blue}\theta}) \right)
\]
\end_inset


\end_layout

\begin_layout Section

\lang french
Décomposition des différentes contributions
\end_layout

\begin_layout Standard

\lang french
Une fois le potentiel 
\begin_inset Formula $\phi ({\color{red}r},{\color{blue}\theta},{\color{green}z})$
\end_inset

 décomposé, on peut l'injecter dans l'équation 
\begin_inset Formula \[
\mu = \sqrt{\phi \, (1+x'^2+y'2)}=\sqrt{\phi} \, \sqrt{1+x'^2+y'2}
\]
\end_inset

afin de déterminer les différentes contributions qui composent l'indice optique. 
\begin_inset space \space{}

\end_inset


\begin_inset Newline newline
\end_inset

 Cependant, on remarque que l'indice optique 
\begin_inset Formula $\nu$
\end_inset

 dépend à l'ordre 2 des dérivées de x et y. Dans la démarche de décomposer les différentes contributions de l'indice optique, il est nécessaire d'effectuer un développement limité de 
\begin_inset Formula \[
\sqrt{1+x'^2+y'2}
\]
\end_inset


\begin_inset space \space{}

\end_inset

On pose X=
\begin_inset Formula $x'^2$
\end_inset

 +
\begin_inset Formula $y'^2$
\end_inset

 afin d'effectuer un changement de variable. 
\begin_inset space \space{}

\end_inset


\begin_inset Newline newline
\end_inset

 
\begin_inset Newline newline
\end_inset

 
