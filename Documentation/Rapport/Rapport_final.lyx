\begin_layout Plain Layout
}
\end_layout

\end_inset

 Une série de Taylor 
\begin_inset Formula $f(x)$
\end_inset

 en 
\begin_inset Formula $x=b$
\end_inset

 s'exprime comme 
\begin_inset Formula $f(x)=\sum\limits_{n=0}^{\infty} a_n(x-b)^n$
\end_inset

. 
\shape default

